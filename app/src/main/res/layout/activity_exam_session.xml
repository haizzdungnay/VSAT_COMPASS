<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- Main content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Top bar: back+subject | question number | timer+grid -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:gravity="center_vertical"
            android:background="@color/white"
            android:elevation="2dp">

            <!-- Left: back + subject -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/btnBack"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_back"
                    android:tint="@color/primary"
                    android:contentDescription="Quay lại" />

                <TextView
                    android:id="@+id/tvExamTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="Toán học"
                    android:textColor="@color/primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />
            </LinearLayout>

            <!-- Center: question number -->
            <TextView
                android:id="@+id/tvQuestionNumber"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Câu 1/50"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <!-- Right: timer + grid -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="end|center_vertical"
                android:orientation="horizontal">

                <!-- Timer in orange box -->
                <TextView
                    android:id="@+id/tvTimer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="10dp"
                    android:background="@drawable/bg_timer_orange"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="5dp"
                    android:text="60:00"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <!-- Grid button -->
                <ImageView
                    android:id="@+id/btnGrid"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_grid"
                    android:tint="@color/primary"
                    android:contentDescription="Danh sách câu hỏi" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tvSyncStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="12dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:text="Sync: local-only"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:background="#F7F8FB" />

        <!-- Progress bar -->
        <ProgressBar
            android:id="@+id/progressQuestion"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:max="100"
            android:progress="0"
            android:progressDrawable="@drawable/progress_green" />

        <!-- Question content -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#F8F8FC">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Question text card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="1dp"
                    app:cardBackgroundColor="@color/white">

                    <TextView
                        android:id="@+id/tvQuestionText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Nội dung câu hỏi..."
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:lineSpacingExtra="4dp"
                        android:padding="16dp" />
                </com.google.android.material.card.MaterialCardView>

                <!-- Answer options container (2-column pairs added programmatically) -->
                <LinearLayout
                    android:id="@+id/llOptions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

            </LinearLayout>
        </ScrollView>

        <!-- Bottom navigation bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp"
            android:background="@color/white"
            android:elevation="6dp"
            android:gravity="center_vertical">

            <!-- Quay lại -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPrevious"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="Quay lại"
                android:textAllCaps="false"
                android:textSize="13sp"
                app:cornerRadius="8dp"
                app:strokeColor="@color/primary" />

            <!-- Đánh dấu (center) -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:layout_marginHorizontal="4dp">

                <ImageView
                    android:id="@+id/btnBookmark"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_flag"
                    android:tint="@color/text_secondary"
                    android:contentDescription="Đánh dấu" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Đánh dấu"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Tiếp theo -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNext"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="Tiếp theo"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:backgroundTint="@color/primary"
                app:cornerRadius="8dp" />
        </LinearLayout>
    </LinearLayout>

</FrameLayout>

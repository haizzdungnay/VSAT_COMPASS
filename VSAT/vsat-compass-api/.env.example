# ============================================
# V-SAT Compass API — Environment Variables
# Copy file này thành .env và điền giá trị thật
# ⚠️ KHÔNG BAO GIỜ commit .env vào git!
# ============================================

# Database (Neon PostgreSQL)
DATABASE_URL=jdbc:postgresql://ep-xxx.ap-southeast-1.aws.neon.tech/vsat_compass?sslmode=require
DATABASE_USERNAME=your_neon_username
DATABASE_PASSWORD=your_neon_password

# JWT Secret (base64 encoded, ít nhất 256-bit / 32 bytes)
# Generate: openssl rand -base64 64
# ⚠️ Giá trị này BẮT BUỘC phải được set. App sẽ KHÔNG khởi động nếu thiếu.
JWT_SECRET=your-base64-encoded-secret-key-at-least-256-bits-long-change-this-in-production

# Spring Profile (dev | prod)
SPRING_PROFILES_ACTIVE=dev

# CORS Allowed Origins (comma-separated, no spaces)
# Mặc định dev: http://localhost:3000,http://localhost:5173
# Prod nên thêm: https://vsat-compass-api.onrender.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# (Optional) Dev-only: enable Hibernate SQL logging
# HIBERNATE_SQL_LOG=DEBUG
